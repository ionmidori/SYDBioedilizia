# =============================================================================
# n8n — Cloud Run Environment Variables
# Copy this file to .env.n8n and fill all values before running deploy.sh
# NEVER commit .env.n8n to git (it contains secrets)
# =============================================================================

# ── n8n Security ──────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
N8N_ENCRYPTION_KEY=

# Web UI basic auth (access n8n dashboard)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# ── PostgreSQL (Neon free tier) ───────────────────────────────────────────────
# Steps to get a free Neon PostgreSQL:
#   1. Go to https://neon.tech → Sign up (free, no credit card)
#   2. Create a new project → name it "syd-n8n"
#   3. Copy the connection string from the dashboard
#   4. Extract the values below from the connection string:
#      postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
#
DB_POSTGRESDB_HOST=
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=neondb
DB_POSTGRESDB_USER=
DB_POSTGRESDB_PASSWORD=

# ── SYD Webhook Security (shared with backend) ────────────────────────────────
# Must match WEBHOOK_SIGNING_KEY in backend_python/.env
SYD_WEBHOOK_SECRET=

# ── Backend URL (for audit callbacks from n8n) ────────────────────────────────
SYD_BACKEND_URL=https://syd-brain-972229558318.europe-west1.run.app

# ── Notifications ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
