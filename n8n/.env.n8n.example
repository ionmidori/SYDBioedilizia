# =============================================================================
# n8n — Cloud Run Environment Variables
# Copy this file to .env.n8n and fill all values before running deploy.sh
# NEVER commit .env.n8n to git (it contains secrets)
# =============================================================================

# ── n8n Security ──────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
N8N_ENCRYPTION_KEY=

# NOTE: n8n v1+ removed N8N_BASIC_AUTH_*. Dashboard access is the built-in user
# management (owner account); the password is reset from the n8n UI.

# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Values come from the Supabase project → Settings → Database:
#   postgresql://USER:PASSWORD@HOST:5432/DATABASE
# The `postgres` role password can only be reset from the Supabase dashboard —
# `ALTER ROLE postgres PASSWORD` over SQL is permission-denied.
#
DB_POSTGRESDB_HOST=
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=
DB_POSTGRESDB_PASSWORD=

# ── SYD Webhook Security (shared with backend) ────────────────────────────────
# Must match WEBHOOK_SIGNING_KEY in backend_python/.env
SYD_WEBHOOK_SECRET=

# ── Backend URL (for audit callbacks from n8n) ────────────────────────────────
SYD_BACKEND_URL=https://syd-brain-972229558318.europe-west1.run.app

# ── Notifications ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
