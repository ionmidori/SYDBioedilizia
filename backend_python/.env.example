# Firebase Configuration (Required)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Internal JWT Secret (Required)
INTERNAL_JWT_SECRET=your-secret-key-here

# Environment: "development" or "production" (default: production / fail-secure)
ENV=production
# DEV ONLY — skips Firebase token verification. Requires ENV=development.
# Startup will FAIL if this is True while ENV != development.
ALLOW_AUTH_BYPASS=false

# Google Gemini API (Required)
GOOGLE_API_KEY=your-gemini-api-key

# Perplexity API (Optional - for market prices)
PERPLEXITY_API_KEY=your-perplexity-key

# Model Armor LLM guardrails (OWASP LLM01/LLM02). Enabled by default but inert
# until a template is configured. Set the template ID (from GCP console) to
# activate input/output filtering in production.
MODEL_ARMOR_ENABLED=true
MODEL_ARMOR_TEMPLATE_ID=
MODEL_ARMOR_LOCATION=europe-west1
