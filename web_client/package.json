{
  "name": "renovation-ai",
  "version": "4.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "lint:fix": "eslint --fix .",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "analyze:server": "cross-env ANALYZE=true BUNDLE_ANALYZE=server next build --webpack",
    "analyze:browser": "cross-env ANALYZE=true BUNDLE_ANALYZE=browser next build --webpack"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ],
    "backend_python/**/*.py": [
      "uv run --project backend_python ruff check --fix --force-exclude"
    ]
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "*",
    "lightningcss-linux-x64-gnu": "^1.33.0"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.34",
    "@firebase/app-check": "^0.12.0",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@rive-app/react-canvas": "^4.29.5",
    "@tanstack/react-query": "^5.101.3",
    "@tanstack/react-query-devtools": "^5.101.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^7.0.5",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "framer-motion": "^12.42.2",
    "gray-matter": "^4.0.3",
    "gsap": "^3.14.2",
    "lenis": "^1.3.25",
    "lucide-react": "1.25.0",
    "next": "^16.2.6",
    "postcss": "^8.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-dropzone": "^19.1.1",
    "react-easy-crop": "^6.2.2",
    "react-hook-form": "^7.82.0",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "react-window": "^2.3.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-window": "^2.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "typescript": "^6"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
