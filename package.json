{
    "name": "renovation-ai-monorepo",
    "version": "4.0.0",
    "private": true,
    "workspaces": [
        "web_client"
    ],
    "scripts": {
        "dev:web": "npm run dev --workspace=web_client",
        "dev:py": "cd backend_python && uv run uvicorn main:app --reload --port 8080",
        "eval:run": "cd backend_python && uv run python tests/evals/run_evals.py --output results/",
        "eval:run:quote": "cd backend_python && uv run python tests/evals/run_evals.py --file quote_flow.test.json --output results/",
        "eval:run:triage": "cd backend_python && uv run python tests/evals/run_evals.py --file triage_flow.test.json --output results/",
        "eval:run:design": "cd backend_python && uv run python tests/evals/run_evals.py --file design_flow.test.json --output results/"
    },
    "dependencies": {
        "form-data": "^2.5.6",
        "minimatch": "10.2.3",
        "next": "^16.2.6",
        "opencode-ai": "^1.1.53",
        "react": "19.2.7",
        "react-dom": "19.2.7"
    },
    "overrides": {
        "fast-xml-parser": "^5.7.0",
        "fast-xml-builder": "^1.1.7",
        "flatted": "3.4.2",
        "protobufjs": "^7.5.8",
        "@protobufjs/utf8": "^1.1.1",
        "node-forge": "^1.4.0",
        "lodash": "^4.18.0",
        "brace-expansion": "^5.0.6",
        "picomatch": "^4.0.4",
        "uuid": "^11.1.1",
        "postcss": "^8.5.10",
        "@tootallnate/once": "^2.0.1",
        "next": "^16.2.6",
        "minimatch": "$minimatch",
        "eslint": {
            "minimatch": "$minimatch"
        },
        "@eslint/config-array": {
            "minimatch": "$minimatch"
        },
        "@eslint/eslintrc": {
            "minimatch": "$minimatch"
        },
        "@typescript-eslint/typescript-estree": {
            "minimatch": "$minimatch"
        },
        "eslint-plugin-import": {
            "minimatch": "$minimatch"
        },
        "eslint-plugin-jsx-a11y": {
            "minimatch": "$minimatch"
        },
        "eslint-plugin-react": {
            "minimatch": "$minimatch"
        },
        "glob": {
            "minimatch": "$minimatch"
        },
        "rimraf": {
            "minimatch": "$minimatch"
        },
        "test-exclude": {
            "minimatch": "$minimatch"
        }
    }
}
